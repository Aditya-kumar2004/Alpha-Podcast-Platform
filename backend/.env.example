# ─── Backend Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# DO NOT commit your .env file — it is in .gitignore.

# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
# Get this from https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/podcast-hub?retryWrites=true&w=majority

# ── Server Port (Vercel ignores this — it manages ports automatically) ─────────
PORT=5000

# ── JWT Secret ─────────────────────────────────────────────────────────────────
# Use a long random string in production.
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ── Nodemailer (Gmail SMTP) ────────────────────────────────────────────────────
# Enable 2-Step Verification on Gmail, then generate an App Password from:
# https://myaccount.google.com/apppasswords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# ── CORS — Your deployed frontend URL ─────────────────────────────────────────
# Example: https://alpha-podcast.vercel.app
FRONTEND_URL=https://your-frontend-vercel-url.vercel.app

# ── Cloudinary (for media file uploads) ───────────────────────────────────────
# Create a free account at https://cloudinary.com
# Dashboard → API Keys → Copy Cloud Name, API Key, API Secret
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
