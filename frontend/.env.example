# ─── Frontend Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your real values

# Your deployed Vercel backend URL (NO trailing slash)
# Example: https://alpha-podcast-backend.vercel.app
# Leave EMPTY for local development — Vite proxy will handle /api/* calls
VITE_API_URL=https://your-backend-vercel-url.vercel.app
